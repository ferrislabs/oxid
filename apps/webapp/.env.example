# --- Runtime (overridable in prod via /config.json) ---
VITE_API_URL=http://localhost:8080
VITE_OIDC_AUTHORITY=https://iam.example.com/realms/oxid

# --- Build-time (baked into the bundle) ---
VITE_OIDC_CLIENT_ID=oxid-webapp
VITE_OIDC_REDIRECT_URI=http://localhost:3000/
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/
VITE_OIDC_SCOPE="openid profile email"
